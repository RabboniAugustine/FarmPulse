# Postgres connection string from Vercel/Neon (Storage tab -> Postgres -> .env.local snippet)
DATABASE_URL="postgres://user:password@host/dbname?sslmode=require"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-secret"

# The deployed URL of your app (Vercel sets this automatically on deploy previews,
# but set it explicitly for production, e.g. https://farmpulse.vercel.app)
NEXTAUTH_URL="http://localhost:3000"

# Used once by `npm run db:seed` to create the first admin account
SEED_ADMIN_EMAIL="admin@farmpulse.app"
SEED_ADMIN_PASSWORD="ChangeMe123!"
